<nav class="site-nav" aria-label="Primary navigation">
  <div class="container">
    <ul>
      {% for item in navigation.primary %}
      <li>
        <a href="{{ item.url }}"
          {% if page.url == item.url or (page.url.startsWith(item.url) and item.url != "/") %}
          aria-current="page"
          {% endif %}>
          {{ item.label }}
        </a>
      </li>
      {% endfor %}
    </ul>
  </div>
</nav>
