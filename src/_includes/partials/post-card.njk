<article class="post-card">
  {% if post.data.image %}
  <a href="{{ post.url }}" class="post-card-image" tabindex="-1" aria-hidden="true">
    <img src="{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.title }}" loading="lazy">
  </a>
  {% endif %}
  <div class="post-card-body">
    <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    <h2 class="post-card-title">
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </h2>
    {% if post.data.summary %}
    <p>{{ post.data.summary }}</p>
    {% endif %}
  </div>
</article>
