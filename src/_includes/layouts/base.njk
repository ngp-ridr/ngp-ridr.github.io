<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title and title != "Home" %}{{ title }} — {% endif %}{{ site.fullTitle }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <meta name="generator" content="{{ eleventy.generator }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  <meta property="og:title" content="{% if title and title != 'Home' %}{{ title }} — {% endif %}{{ site.fullTitle }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="{{ ogType or 'website' }}">
  {% if image %}<meta property="og:image" content="{{ site.url }}{{ image }}">{% endif %}

  <link rel="stylesheet" href="/assets/css/main.css">
  <link rel="stylesheet" href="/assets/css/layout.css">
  <link rel="stylesheet" href="/assets/css/components.css">

  {% if mapEnabled %}
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="">
  {% endif %}

  {% block head %}{% endblock %}
</head>
<body>

  <a class="skip-link" href="#main-content">Skip to main content</a>

  {% include "partials/header.njk" %}
  {% include "partials/nav.njk" %}

  <main id="main-content" tabindex="-1">
    {% block content %}
      {{ content | safe }}
    {% endblock %}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/assets/js/main.js" type="module"></script>

  {% if mapEnabled %}
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV/XN/WLs=" crossorigin=""></script>
  <script src="/assets/js/map-init.js" type="module"></script>
  {% endif %}

  {% if chartEnabled %}
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
  <script src="/assets/js/chart-init.js" type="module"></script>
  {% endif %}

  {% block scripts %}{% endblock %}

</body>
</html>
